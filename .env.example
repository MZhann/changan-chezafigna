# Токен бота от @BotFather
BOT_TOKEN=

# Ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Модель. По умолчанию самая дешёвая адекватная — gpt-4o-mini.
# Ещё дешевле: gpt-4.1-nano. Поумнее: gpt-4.1-mini.
OPENAI_MODEL=gpt-4o-mini

# Слово-триггер (на что реагирует бот в начале сообщения)
TRIGGER=чанган
